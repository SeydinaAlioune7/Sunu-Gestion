# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de données SQLite (Railway volume persistant) ────────────────────────
# Sur Railway : mettre /data/app.db
# En local : laisser vide (utilise backend/db/app.db)
DB_PATH=/data/app.db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=REMPLACER_PAR_UNE_VRAIE_CLE_SECRETE_64_CHARS
REFRESH_SECRET=REMPLACER_PAR_UNE_AUTRE_CLE_SECRETE_64_CHARS

# ── Cryptage AES-256 ─────────────────────────────────────────────────────────
MASTER_ENCRYPTION_KEY=REMPLACER_PAR_64_CARACTERES_HEX

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://sunugestion.sn

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_NAME=Sunu Gestion
